getVideoUpdatesByWatchedStatus:
SELECT
    V.profile_id,
    V._id,
    V.title,
    VE._id,
    VE.name,
    VE.url,
    VE.watched,
    VE.completed,
    V.source,
    V.favorite,
    V.thumbnail_url,
    0 AS cover_last_modified,
    VE.date_fetch
FROM video_episodes VE
JOIN videos V
ON VE.video_id = V._id
WHERE V.profile_id = :profileId
AND VE.profile_id = :profileId
AND V.favorite = 1
AND VE.watched = :watched
AND VE.date_fetch > :after
ORDER BY VE.date_fetch DESC
LIMIT :limit;
